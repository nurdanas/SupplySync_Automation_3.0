<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Test Suite" parallel="classes" thread-count="6">
    <test name="Regression Test">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="tests"></package>
        </packages>
    </test>
    <listeners>
        <listener class-name="listeners.TimingListener"></listener>
    </listeners>
<!--    Total execution time: 20 seconds instead of 1:17 seconds-->

</suite>