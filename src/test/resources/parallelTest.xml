<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Parallel Test Suite" parallel="classes" thread-count="3">
    <test name="Parallel Test">
        <classes>
            <class name="tests.ProjectLoginTests"/>
            <class name="tests.MastersTests"/>
            <class name="tests.RegionsTests">
                <methods>
                    <exclude name="shouldEditRegionSuccessfully"></exclude>
                </methods>
            </class>
        </classes>
    </test>
    <listeners>
        <listener class-name="listeners.TimingListener"></listener>
    </listeners>
<!--    Total execution time: 19 seconds instead of 41 seconds-->
</suite>
