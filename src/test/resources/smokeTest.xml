<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="Smoke Test Suite">
    <test name="Smoke Test">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <classes>
            <class name="tests.MainPageTests"/>
            <class name="tests.OrdersTest"></class>
            <class name="tests.MastersTests"></class>
            <class name="tests.RegionsTests"></class>
            <class name="tests.BranchTests"></class>
        </classes>
    </test>

</suite>